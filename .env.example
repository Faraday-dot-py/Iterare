# Anthropic API
ANTHROPIC_API_KEY=your_key_here

# PostgreSQL (LangGraph checkpointer)
# Local: postgresql://user:password@localhost:5432/iterare
ITERARE_DB_URL=postgresql://iterare:iterare@localhost:5432/iterare

# Model (default: claude-sonnet-4-6)
ITERARE_MODEL=claude-sonnet-4-6

# Root path for file operations (default: repo root)
ITERARE_ROOT=/home/awebb/Research/iterare

# Max worker retry attempts before escalation (default: 3)
ITERARE_MAX_WORKER_ATTEMPTS=3
